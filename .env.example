# =============================================================================
# Venmo — Environment Variables
# Copy to .env and fill in values. Never commit .env to version control.
# =============================================================================

# Application
NODE_ENV=development

# Backend server
PORT=3001
CORS_ORIGIN=http://localhost:3000

# Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=change-me-to-a-random-64-char-hex-string
JWT_EXPIRES_IN=7d

# Database (PostgreSQL)
POSTGRES_USER=venmo
POSTGRES_PASSWORD=venmo_dev
POSTGRES_DB=venmo_dev
POSTGRES_PORT=5432
DATABASE_URL=postgres://venmo:venmo_dev@localhost:5432/venmo_dev

# Redis (for sessions / rate limiting)
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# Frontend (Next.js)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Payment integrations (configure once VEN-4 tech decisions are finalized)
# PLAID_CLIENT_ID=
# PLAID_SECRET=
# PLAID_ENV=sandbox
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
